class Solution {
    public ListNode deleteDuplicates(ListNode head) {
        if(head==null){
            return null;
        }
      ListNode previous=head;
      ListNode curr=head.next;
      while(curr!=null){
        if(previous.val==curr.val){
            curr=curr.next;
            previous.next=curr;
        }else{
            curr=curr.next;
            previous=previous.next;
        }
      }
      return head;
    }
}
